// LAM animation
%TEMP_HANDS%:loadfromfile(sources\wpn_hand_01.ogf)
%TEMP_HANDS%.skeleton:loadomf(sources\wpn_hand_vintorez_hud_animation.omf)
%HANDS%.skeleton.animation[name:sks_fab_idle]:duplicate(sks_fab_lam)
%HANDS%.skeleton.animation[name:sks_fab_lam]:setlength(36):setflags(2)
%TEMP_HANDS%.skeleton.animation[name:vss_lam]:copytrack(0,-1, lead_gun | %L_FINGER_0%)
%HANDS%.skeleton.animation[name:sks_fab_lam]:pastetrack(0,0)
%TEMP_HANDS%:unload()

%HANDS%.skeleton.animation[name:sks_fab_idle]:copykey(0)
%HANDS%.skeleton.animation[name:sks_fab_lam]:pastekey(0)
%HANDS%.skeleton.animation[name:sks_fab_lam].bone[expr:lead_gun | l_finger0]:applydiff(0, -1, 1, -1)

%HANDS%.skeleton.iksolver:simplelimb(l_hand, x, xz)
%HANDS%.skeleton.animation[name:sks_fab_lam]:setikrefpose(0)
%HANDS%.skeleton.animation[name:sks_fab_lam].bone[name:l_hand]:followbone(lead_gun, 0, 1, -1)

%HANDS%.skeleton.animation[name:sks_fab_lam].bone[name:l_hand]:move(0.001,-0.013,0.008, 12,14, 0,0):rotate(-2,0,0, 12,14, 1)
%HANDS%.skeleton.animation[name:sks_fab_lam]:setikrefpose(8)
%HANDS%.skeleton.animation[name:sks_fab_lam].bone[name:l_hand]:interpolate(8,12,1,1,1.2):interpolate(14,20,1,1,0.8)
%HANDS%.skeleton.iksolver:reset()

%HANDS%.skeleton.iksolver:simplelimb(r_hand, x, xz)
%HANDS%.skeleton.animation[name:sks_fab_lam].bone[name:r_hand]:followbone(lead_gun, 0, 1, -1)
%HANDS%.skeleton.iksolver:reset()

%HANDS%.skeleton.animation[name:sks_fab_idle]:copykey(0, %L_FINGER_0%)
%HANDS%.skeleton.animation[name:sks_fab_lam]:pastekey(20,-1)
%HANDS%.skeleton.animation[name:sks_fab_lam].bone[expr:%L_FINGER_0%]:interpolate(14,20,1,1,0.8)

// Prepare animation for scopes

%HUD%.skeleton.animation[name:idle]:duplicate(idle_aim)
%HUD%.skeleton.animation[name:idle_empty]:duplicate(idle_aim_empty)
%HUD%.skeleton.animation[name:idle_jammed]:duplicate(idle_aim_jammed)
