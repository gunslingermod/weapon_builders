// Create sights animation
set MARK_OFFSET = 0,-10,0
set MARK_OFFSET_REV = 0,10,0
set SHOW_SIGHTS_FRAME = 5
set HIDE_SIGHTS_FRAME = 5

// sights that go to DOWN in aim
set BONES_DOWN = scope_rakurs_lense | scope_aimpoint_lense | scope_pka_lense
%HUD%.skeleton.animation[name:idle_aim*].bone[expr:%BONES_DOWN%]:move(%MARK_OFFSET%,0,-1)
%HUD%.skeleton.animation[name:shoot_aim*].bone[expr:%BONES_DOWN%]:move(%MARK_OFFSET%,0,-1)
%HUD%.skeleton.animation[name:idle_start_aim*].bone[expr:%BONES_DOWN%]:move(%MARK_OFFSET%,%SHOW_SIGHTS_FRAME%,-1)
%HUD%.skeleton.animation[name:idle_end_aim*].bone[expr:%BONES_DOWN%]:move(%MARK_OFFSET%,0,%HIDE_SIGHTS_FRAME%)
unset BONES_DOWN

// sights that go to NORMAL in aim
set BONES_NORMAL = scope_eotech_sight | scope_aimpoint_sight | scope_cobra_sight | scope_pka_sight
%HUD%.skeleton.animation[].bone[expr:%BONES_NORMAL%]:move(%MARK_OFFSET%, 0, -1)
%HUD%.skeleton.animation[name:idle_aim*].bone[expr:%BONES_NORMAL%]:move(%MARK_OFFSET_REV%,0,-1)
%HUD%.skeleton.animation[name:shoot_aim*].bone[expr:%BONES_NORMAL%]:move(%MARK_OFFSET_REV%,0,-1)
%HUD%.skeleton.animation[name:idle_start_aim*].bone[expr:%BONES_NORMAL%]:move(%MARK_OFFSET_REV%,%SHOW_SIGHTS_FRAME%,-1)
%HUD%.skeleton.animation[name:idle_end_aim*].bone[expr:%BONES_NORMAL%]:move(%MARK_OFFSET_REV%,0,%HIDE_SIGHTS_FRAME%)
unset BONES_NORMAL

unset MARK_OFFSET
unset MARK_OFFSET_REV
unset SHOW_SIGHTS_FRAME
unset HIDE_SIGHTS_FRAME

:LABEL_FINAL

%HUD%.skeleton:saveomf(sks\wpn_sks_hud_animation.omf):resetmotionrefs():addmotionref(dynamics\weapons\wpn_sks\wpn_sks_hud_animation)
%HUD%:savetofile(sks\wpn_sks_hud.ogf)

%HANDS%.skeleton:saveomf(sks\wpn_hand_sks_hud_animation.omf)

:FINISH