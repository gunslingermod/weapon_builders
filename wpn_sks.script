%HANDS%.skeleton.animation[name:sks_sprint_end]:remove()
%HANDS%.skeleton.animation[name:sks_fab_sprint_end]:remove()
%HANDS%.skeleton.animation[name:sks_revival]:remove()
%HANDS%.skeleton.animation[name:sks_fab_revival]:remove()
%HANDS%.skeleton.animation[name:sks_fab_dry]:remove()
%HANDS%.skeleton.animation[name:sks_fab_shoot]:remove()
%HANDS%.skeleton.animation[name:sks_fab_shoot1]:remove()
%HANDS%.skeleton.animation[name:sks_fab_shoot2]:remove()
%HANDS%.skeleton.animation[name:sks_reload_end]:remove()
%HANDS%.skeleton.animation[name:sks_shoot]:remove()
%HANDS%.skeleton.animation[name:sks_shoot1]:remove()
%HANDS%.skeleton.animation[name:sks_shoot2]:remove()
%HANDS%.skeleton:mergeomf(sources\sks_hands_additional.omf)

//correct left hand position to prevent collision with exo
set CORRECTION = 0,-0.001,0.025
%HANDS%.skeleton.animation[].bone[name:l_clavicle]:move(%CORRECTION%,0,-1)

// Rollback correction for left-handed operations
set CORRECTION = 0,0.001,-0.025
%HANDS%.skeleton.animation[name:sks_reload].bone[name:l_clavicle]:move(%CORRECTION%,5,114):interpolate(1,5):interpolate(114,118)
%HANDS%.skeleton.animation[name:sks_fab_reload].bone[name:l_clavicle]:move(%CORRECTION%,5,114):interpolate(1,5):interpolate(114,118)
%HANDS%.skeleton.animation[name:sks_reload_empty].bone[name:l_clavicle]:move(%CORRECTION%,5,111):interpolate(1,5):interpolate(111,115)
%HANDS%.skeleton.animation[name:sks_fab_reload_empty].bone[name:l_clavicle]:move(%CORRECTION%,5,111):interpolate(1,5):interpolate(111,115)
%HANDS%.skeleton.animation[name:sks_reload_empty].bone[name:l_clavicle]:move(%CORRECTION%,5,111):interpolate(1,5):interpolate(111,115)
%HANDS%.skeleton.animation[name:sks_fab_reload_empty].bone[name:l_clavicle]:move(%CORRECTION%,5,111):interpolate(1,5):interpolate(111,115)
unset CORRECTION

%HANDS%.skeleton:mergeomf(sources\sks_hands_additional_nocorrection.omf)
%HANDS%.skeleton.animation[name:sks_fab_lam]:rename(sks_fab_lam_new)

%HANDS%.skeleton.animation[]:setpower(1)

%HANDS%.skeleton.animation[name:sks_reload_end]:setlength(41):setflags(2):setspeed(1.3)
%HANDS%.skeleton.animation[name:sks_reload_start]:setlength(65):setflags(2):setspeed(1.3)
%HANDS%.skeleton.animation[name:sks_reload_empty_start]:setlength(45):setflags(2):setspeed(1.5)
%HANDS%.skeleton.animation[name:sks_reload_ammo]:setlength(36):setflags(2):setspeed(1.5)

%HUD%.skeleton.animation[name:reload_end]:setlength(41):setflags(2):setspeed(1.3)
%HUD%.skeleton.animation[name:reload_start]:setlength(65):setflags(2):setspeed(1.3)
%HUD%.skeleton.animation[name:reload_empty_start]:setlength(45):setflags(2):setspeed(1.5)
%HUD%.skeleton.animation[name:reload_ammo]:setlength(36):setflags(2):setspeed(1.5)

%HANDS%.skeleton.animation[name:sks_reload]:setspeed(1.166)
%HANDS%.skeleton.animation[name:sks_reload_empty]:setspeed(1.166)
%HANDS%.skeleton.animation[name:sks_fab_reload]:setspeed(1.166)
%HANDS%.skeleton.animation[name:sks_fab_reload_empty]:setspeed(1.166)
%HUD%.skeleton.animation[name:reload]:setspeed(1.166)
%HUD%.skeleton.animation[name:reload_empty]:setspeed(1.166)

//correct left finger for single-ammo reload 
set FINGER_CORRECTION = 0,5,3
%HANDS%.skeleton.animation[name:sks_reload_ammo].bone[name:l_finger0]:rotate(%FINGER_CORRECTION%, 0,-1, 0)
//%HANDS%.skeleton.animation[name:sks_reload_end].bone[name:l_finger0]:rotate(%FINGER_CORRECTION%, 0,30, 0):interpolate(30,35)
%HANDS%.skeleton.animation[name:sks_reload_empty_start].bone[name:l_finger0]:rotate(%FINGER_CORRECTION%, 15,-1, 0):interpolate(10,15)
%HANDS%.skeleton.animation[name:sks_reload_start].bone[name:l_finger0]:rotate(%FINGER_CORRECTION%, 13,-1, 0):interpolate(5,13)
unset FINGER_CORRECTION

