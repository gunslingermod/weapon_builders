const L_FINGER_0 = l_finger0 | l_finger01 | l_finger02
const L_FINGER_1 = bip01_l_finger1 | bip01_l_finger11 | bip01_l_finger12
const L_FINGER_2 = bip01_l_finger2 | bip01_l_finger21 | bip01_l_finger22
const L_FINGER_3 = bip01_l_finger3 | bip01_l_finger31 | bip01_l_finger32
const L_FINGER_4 = bip01_l_finger4 | bip01_l_finger41 | bip01_l_finger42
const L_FINGERS_ALL = %L_FINGER_0% | %L_FINGER_1% | %L_FINGER_2% | %L_FINGER_3% | %L_FINGER_4%

const L_HAND_FULL = l_hand | %L_FINGERS_ALL% 
const L_LIMB_NOHAND = l_clavicle | l_upperarm | l_forearm | l_forearm_twist 
const L_LIMB_NOFINGERS = %L_LIMB_NOHAND% | l_hand
const L_LIMB_FULL = %L_LIMB_NOFINGERS% | %L_FINGERS_ALL%

const R_FINGER_0 = r_finger0 | r_finger01 | r_finger02
const R_FINGER_1 = bip01_r_finger1 | bip01_r_finger11 | bip01_r_finger12
const R_FINGER_2 = bip01_r_finger2 | bip01_r_finger21 | bip01_r_finger22
const R_FINGER_3 = bip01_r_finger3 | bip01_r_finger31 | bip01_r_finger32
const R_FINGER_4 = bip01_r_finger4 | bip01_r_finger41 | bip01_r_finger42
const R_FINGERS_ALL = %R_FINGER_0% | %R_FINGER_1% | %R_FINGER_2% | %R_FINGER_3% | %R_FINGER_4%

const R_HAND_FULL = r_hand | %R_FINGERS_ALL% 
const R_LIMB_NOHAND = r_clavicle | r_upperarm | r_forearm | r_forearm_twist 
const R_LIMB_NOFINGERS = %R_LIMB_NOHAND% | r_hand
const R_LIMB_FULL = %R_LIMB_NOFINGERS% | %R_FINGERS_ALL%


const HUD = model1
const HANDS = model3
const TEMP = model2
const TEMP_HANDS = model4
const WORLD = model5

