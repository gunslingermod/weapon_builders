%HUD%.skeleton.animation[name:idle]:duplicate(idle_start_aim)
%HUD%.skeleton.animation[name:idle_empty]:duplicate(idle_start_aim_empty)
%HUD%.skeleton.animation[name:idle_jammed]:duplicate(idle_start_aim_jammed)
%HUD%.skeleton.animation[name:idle_start_aim*]:setlength(15):setflags(2)

%HUD%.skeleton.animation[name:idle]:duplicate(idle_end_aim)
%HUD%.skeleton.animation[name:idle_empty]:duplicate(idle_end_aim_empty)
%HUD%.skeleton.animation[name:idle_jammed]:duplicate(idle_end_aim_jammed)
%HUD%.skeleton.animation[name:idle_end_aim*]:setlength(15):setflags(2)

%HUD%.skeleton.animation[name:shoot]:duplicate(shoot_aim)
%HUD%.skeleton.animation[name:shoot_jammed]:duplicate(shoot_aim_jammed)
%HUD%.skeleton.animation[name:shoot_last]:duplicate(shoot_aim_last)

%HUD%.selection:pivotpoint(0.071,-0.074,0.448)
%HUD%.mesh.child[texture:wpn\sks\wpn_dovetail]:scale(0.95, 0.9, 0.9):move(0.002,0,0)
%HUD%.selection:reset()

