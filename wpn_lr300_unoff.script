// !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! HUD MODEL ANIMATIONS !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
model2:loadfromfile(sources\wpn_sig550_hud.ogf)
model2.skeleton:loadomf(sources\wpn_sig550_hud_animation.omf)

// -------------- Correct shell position in the last shoot frames --------------
model1.skeleton.animation[name:idle]:copykey(0, shell)
model1.skeleton.animation[name:aim_shoot*]:pastekey(0)
model1.skeleton.animation[name:aim_shoot*].bone[name:shell]:clonekey(0, 6, -1)
model1.skeleton.animation[name:aim_shoot*]:setaccrue(10):setfalloff(10)
model1.skeleton.animation[name:shoot*]:setaccrue(10):setfalloff(10)

// -------------- move aim marks outside of player's view in all animations --------------
model1.skeleton.animation[].bone[expr:s_aimpoint_metka | s_eot_metka]:move(0, -10, 0, 0, -1, 0, 0)

// -------------- aim_start - show marks --------------
model1.skeleton.animation[name:idle]:duplicate(aim_start)
model1.skeleton.animation[name:idle_empty]:duplicate(aim_start_empty)
model1.skeleton.animation[name:idle_jammed]:duplicate(aim_start_jammed)
model1.skeleton.animation[name:aim_start*]:setlength(9)
model1.skeleton.animation[name:aim_start*].bone[expr:s_aimpoint_metka | s_eot_metka]:move(0, 10, 0, 4, -1, 0, 0)
model1.skeleton.animation[name:aim_start*].bone[expr:s_aimpoint_lense]:move(0, -10, 0, 4, -1, 0, 0)

// -------------- aim_idle - marks always visible --------------
model1.skeleton.animation[name:idle]:duplicate(aim_idle)
model1.skeleton.animation[name:idle_empty]:duplicate(aim_idle_empty)
model1.skeleton.animation[name:idle_jammed]:duplicate(aim_idle_jammed)
model1.skeleton.animation[name:aim_idle*]:setlength(1)
model1.skeleton.animation[name:aim_idle*].bone[expr:s_aimpoint_metka | s_eot_metka]:move(0, 10, 0, 0, -1, 0, 0)
model1.skeleton.animation[name:aim_idle*].bone[expr:s_aimpoint_lense]:move(0, -10, 0, 0, -1, 0, 0)

// -------------- aim_shoot - marks always shown --------------
model1.skeleton.animation[name:aim_shoot*].bone[expr:s_aimpoint_metka | s_eot_metka]:move(0, 10, 0, 0, -1, 0, 0)
model1.skeleton.animation[name:aim_shoot*].bone[expr:s_aimpoint_lense]:move(0, -10, 0, 0, -1, 0, 0)

// -------------- aim_end - hide marks --------------
model1.skeleton.animation[name:idle]:duplicate(aim_end)
model1.skeleton.animation[name:idle_empty]:duplicate(aim_end_empty)
model1.skeleton.animation[name:idle_jammed]:duplicate(aim_end_jammed)
model1.skeleton.animation[name:aim_end*]:setlength(5)
model1.skeleton.animation[name:aim_end*].bone[expr:s_aimpoint_metka | s_eot_metka]:move(0, 10, 0, 0, 2, 0, 0)
model1.skeleton.animation[name:aim_end*].bone[expr:s_aimpoint_lense]:move(0, -10, 0, 0, 2, 0, 0)

// -------------- Firemode - from auto to single --------------
model1.skeleton.animation[name:idle]:duplicate(firemode_single)
model1.skeleton.animation[name:idle_empty]:duplicate(firemode_single_empty)
model1.skeleton.animation[name:idle_jammed]:duplicate(firemode_single_jammed)
model1.skeleton.animation[name:m4_glon_idle]:duplicate(firemode_single_glon)
model1.skeleton.animation[name:m4_glon_idle_empty]:duplicate(firemode_single_glon_empty)
model1.skeleton.animation[name:m4_glon_idle_jammed]:duplicate(firemode_single_glon_jammed)
model1.skeleton.animation[name:firemode_single*]:setlength(26):setaccrue(0):setfalloff(0):setspeed(1):setpower(1):setflags(2)
model1.skeleton.animation[name:firemode_single*].bone[expr:firemode_a]:rotate(90,0,0, 13, -1)
model1.skeleton.animation[name:firemode_single*].bone[expr:firemode_1]:rotate(-90,0,0, 0, 11)
model1.skeleton.animation[name:firemode_single*].bone[name:firemode_*]:interpolate(11, 13,true,true)

// -------------- Firemode - from single to auto --------------
model1.skeleton.animation[name:idle]:duplicate(firemode_auto)
model1.skeleton.animation[name:idle_empty]:duplicate(firemode_auto_empty)
model1.skeleton.animation[name:idle_jammed]:duplicate(firemode_auto_jammed)
model1.skeleton.animation[name:m4_glon_idle]:duplicate(firemode_auto_glon)
model1.skeleton.animation[name:m4_glon_idle_empty]:duplicate(firemode_auto_glon_empty)
model1.skeleton.animation[name:m4_glon_idle_jammed]:duplicate(firemode_auto_glon_jammed)
model1.skeleton.animation[name:firemode_auto*]:setlength(26):setaccrue(0):setfalloff(0):setspeed(1):setpower(1):setflags(2)
model1.skeleton.animation[name:firemode_auto*].bone[expr:firemode_1]:rotate(-90,0,0, 11, -1)
model1.skeleton.animation[name:firemode_auto*].bone[expr:firemode_a]:rotate(90,0,0, 0, 9)
model1.skeleton.animation[name:firemode_auto*].bone[name:firemode_*]:interpolate(9, 11,true,true)

// --------------  correct glon_idle's to prevent 'grenade drop' in the start of reload -------------- 
model1.skeleton.animation[name:m4_glon_idle*]:setaccrue(0):setfalloff(0)

// -------------- make gl_changegrenade from sg550_gl_changegrenade ---------------------
model1.skeleton.animation[name:m4_glon_idle]:duplicate(gl_changegrenade)
model1.skeleton.animation[name:m4_glon_idle_empty]:duplicate(gl_changegrenade_empty)
model1.skeleton.animation[name:m4_glon_idle_jammed]:duplicate(gl_changegrenade_jammed)
model1.skeleton.animation[name:gl_changegrenade*]:setlength(1):setspeed(1):setpower(1):setaccrue(5):setfalloff(10):setflags(2)
model2.skeleton.animation[name:sg550_gl_changegrenade]:copytrack(0, -1, wpn_launcher_grenade | wpn_launcher_grenade_blue | wpn_launcher_grenade_red | wpn_launcher_barrel | wpn_launcher_shell)
model1.skeleton.animation[name:gl_changegrenade*]:pastetrack(0, 0)
model2:unload()

// -------------- remove m4 prefix from all weapon's anims ------------------------------
model1.skeleton.animation[name:m4_*]:rename(*)

// -------------- correct gl_reload prevent 'grenade drop' in the start  -----------------------------------------------------
model1.skeleton.animation[name:gl_reload*]:setaccrue(0):setfalloff(0)

// -------------- Correct grenade launcher position --------------
model1.skeleton.animation[].bone[name:wpn_launcher]:move(0,-0.02, 0, 0, -1, 0, 0)
model1.skeleton.animation[].bone[name:wpn_launcher_sight]:move(0,0.02, 0, 0, -1, 0, 0)

// -------------- Correct texture name to avoid future conflicts -------
model1.mesh.child[texture:wpn\wpn_lr300]:settexture(wpn\wpn_lr300_unoff)
