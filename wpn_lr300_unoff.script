// -------------- correct bolr movement in revival --------------
model1.skeleton.animation[name:revival].bone[name:bolt]:clonekey(0,1,30)

// -------------- Correction of reload_empty animation ------------------------------------------------------
model1.selection:pivotpoint(0.1275,-0.168,0.598)
model1.mesh.child[texture:wpn\ammo_5x56]:scale(0.97, 0.97, 0.97)
model1.selection:pivotpoint(0,0,0)

model1.skeleton.animation[name:idle]:copykey(0, shell)
model1.skeleton.animation[name:reload_empty_new]:pastekey(0,-1)

model1.skeleton.animation[name:reload_empty_new]:duplicate(reload)

model1.skeleton:addbone(ammo_additional, ammo2, 0,0,0,0,0,0,0)
model1.skeleton.bone[name:ammo_additional]:reparent(magazin)
model1.mesh.child[texture:wpn\ammo_5x56]:copy()
model1.mesh.child1:paste():filterbone(!ammo2):rebind(ammo_additional)

model1.skeleton.animation[name:idle].bone[name:ammo_additional]:move(0.005,-0.1,0, 0,0)
model1.skeleton.animation[name:idle].bone[expr:ammo1 | ammo2]:move(0,0.005,0, 0,0)
model1.skeleton.animation[name:idle]:copykey(0, ammo_additional | ammo1 | ammo2)
model1.skeleton.animation[name!reload_empty_new]:pastekey(0,-1)


model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo1 | ammo2]:move(0,0.005,0, 0,0):clonekey(0,1,32):clonekey(0,58,-1)

model1.skeleton.animation[name:reload_empty_new].bone[name:ammo_additional]:move(0,0.01,0, 0,0)
model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo1 | ammo2]:move(0,-0.005,0, 0,0)
model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo1 | ammo2 | ammo_additional]:clonekey(0, 33,57)
model1.skeleton.animation[name:reload_empty_new]:copykey(1, ammo1 | ammo2 | ammo_additional):pastekey(0)

model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo2 | ammo_additional]:move(0.005,-0.04,0, 0,0)
model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo1]:move(-0.005,-0.04,0, 0,0)
model1.skeleton.animation[name:reload_empty_new].bone[expr:ammo1 | ammo2 | ammo_additional]:clonekey(0, 1,32)


model1.skeleton.animation[name:gloff_reload_empty]:remove()
model1.skeleton.animation[name:reload_empty_new]:rename(reload_empty)

model1.skeleton.animation[].bone[name:bolt_holder_new]:followbone(bolt_holder, 0, 0, -1)


